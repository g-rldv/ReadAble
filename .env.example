# ============================================================
# .env.example — copy to .env and fill in your values
# ============================================================

# ── Backend ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# PostgreSQL connection string (from Render.com)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://readable_user:password@localhost:5432/readable

# JWT secret key (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Frontend URL for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────
# URL where the backend API is running
VITE_API_URL=http://localhost:5000
